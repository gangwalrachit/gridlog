# GridLog — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ENTSO-E Transparency API — register at https://transparency.entsoe.eu/
ENTSOE_API_TOKEN=your-token-here

# PostgreSQL (series catalogue)
POSTGRES_USER=gridlog
POSTGRES_PASSWORD=gridlog
POSTGRES_DB=gridlog
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ClickHouse (time-series values)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=gridlog
